HIGGS_VENV=/root/higgs-audio-v3-env
HIGGS_MODEL_DIR=/root/models/higgs-audio-v3-tts-4b-transformers
HIGGS_TOKENIZER_DIR=/root/models/higgs-audio-v2-tokenizer
